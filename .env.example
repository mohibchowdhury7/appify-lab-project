# ──────────────────────────────────────────────
# Buddy Script — Environment Variables
# Copy to .env and fill in values for local development
# ──────────────────────────────────────────────

# API (apps/api)
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (Supabase Postgres or local)
# Transaction-mode pooler (IPv4 — used for Prisma queries)
DATABASE_URL=postgresql://postgres.efcattzvbpxftwaikzjq:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session-mode pooler (used for Prisma migrations)
DIRECT_URL=postgresql://postgres.efcattzvbpxftwaikzjq:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# JWT secrets (use strong random strings in production)
JWT_SECRET=your-jwt-access-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Supabase (Storage + optional DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
STORAGE_BUCKET=post-images

# Web (apps/web) — must be prefixed with VITE_
VITE_API_BASE_URL=http://localhost:3000
